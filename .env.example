# Base de datos (PostgreSQL — obtener de Supabase > Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Supabase REST API (opcional, para funciones avanzadas)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-anon-key

# ARCA/AFIP
ARCA_CUIT=30712345678
ARCA_CERT_PATH=/etc/pos/certs/empresa.crt
ARCA_KEY_PATH=/etc/pos/certs/empresa.key
ARCA_ENV=testing
ARCA_PUNTO_VENTA=1

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-cuenta@gmail.com
SMTP_PASS=tu-app-password

# Impresora Gadnic
PRINTER_PORT=/dev/ttyUSB0
PRINTER_BAUD=9600

# Server
PORT=8080

# Auth — obligatorio, sin valor por defecto. Generar con: openssl rand -hex 32
JWT_SECRET=
